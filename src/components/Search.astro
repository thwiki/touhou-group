---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const listEntries = (await getCollection('lists')).sort((a, b) => a.data.id - b.data.id);

// 获取所有唯一的标签
const allLabels = new Set<string>();
listEntries.forEach((entry: CollectionEntry<'lists'>) => {
	entry.data.sections.forEach((section) => {
		section.groups.forEach((group) => {
			group.labels.forEach((label: string) => allLabels.add(label));
		});
	});
});

export type Props = {
	title?: string;
};

const { title = '东方相关 QQ 群组列表' } = Astro.props;
---

<div class="mb-8 mt-8 flex justify-center">
	<div class="relative w-full max-w-md">
		<input
			type="text"
			id="search-input"
			class="w-full rounded-full border border-gray-200 bg-gray-50 px-6 py-3 text-sm shadow-sm transition-all duration-300 placeholder:text-gray-400 focus:-translate-y-0.5 focus:border-amber-500 focus:bg-white focus:shadow-lg focus:outline-none focus:ring-2 focus:ring-amber-500"
			placeholder={`在${title}中搜索标签/群号/群名/群简介...`}
		/>
		<svg
			xmlns="http://www.w3.org/2000/svg"
			fill="none"
			viewBox="0 0 24 24"
			stroke-width="1.5"
			stroke="currentColor"
			class="pointer-events-none absolute right-4 top-1/2 h-5 w-5 -translate-y-1/2 text-gray-400"
		>
			<path
				stroke-linecap="round"
				stroke-linejoin="round"
				d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"></path>
		</svg>
	</div>
</div>
<div
	id="no-results"
	class="search-empty-state mt-4 translate-y-2 text-center text-gray-500 opacity-0"
	hidden
>
	没有找到匹配的群组
</div>

<script>
	const FILTER_OUT_CLASS = 'is-filtering-out';
	const FILTER_VISIBLE_CLASS = 'is-visible';
	const FILTER_DELAY = 170;
	const globalScope = window as typeof window & {
		__touhouSearchListenersBound?: boolean;
	};

	function applyHighlight(element: HTMLElement, text: string, query: string) {
		element.replaceChildren();
		if (!query) {
			element.appendChild(document.createTextNode(text));
			return;
		}
		const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
		const regex = new RegExp(escaped, 'gi');
		let lastIndex = 0;
		let match: RegExpExecArray | null;
		while ((match = regex.exec(text)) !== null) {
			if (match.index > lastIndex) {
				element.appendChild(document.createTextNode(text.slice(lastIndex, match.index)));
			}
			const mark = document.createElement('mark');
			mark.className = 'rounded bg-amber-200/80 px-0.5 text-inherit';
			mark.appendChild(document.createTextNode(match[0]));
			element.appendChild(mark);
			lastIndex = regex.lastIndex;
		}
		if (lastIndex < text.length) {
			element.appendChild(document.createTextNode(text.slice(lastIndex)));
		}
	}

	function setAnimatedVisibility(
		element: HTMLElement,
		shouldShow: boolean,
		timerKey: 'hideTimerId' | 'sectionHideTimerId'
	) {
		const scheduledTimer = element.dataset[timerKey];
		if (scheduledTimer) {
			window.clearTimeout(Number(scheduledTimer));
			delete element.dataset[timerKey];
		}

		if (shouldShow) {
			element.hidden = false;
			requestAnimationFrame(() => {
				element.classList.remove(FILTER_OUT_CLASS);
			});
			return;
		}

		element.classList.add(FILTER_OUT_CLASS);
		element.dataset[timerKey] = String(
			window.setTimeout(() => {
				element.hidden = true;
				delete element.dataset[timerKey];
			}, FILTER_DELAY)
		);
	}

	function initSearch() {
		const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
		const noResults = document.getElementById('no-results') as HTMLElement | null;

		if (!searchInput || !noResults || searchInput.dataset.searchReady === 'true') {
			return;
		}

		const searchField = searchInput;
		const noResultsElement = noResults;

		searchField.dataset.searchReady = 'true';

		const sections = Array.from(document.querySelectorAll<HTMLElement>('section'));
		const sectionVisibility = new Map<string, boolean>();
		const cardCache = Array.from(document.querySelectorAll<HTMLElement>('[data-group-card]')).map(
			(card) => {
				const labelElements = Array.from(
					card.querySelectorAll<HTMLElement>('[data-group-role="labels"] > div')
				);
				const groupIdElement = card.querySelector<HTMLElement>('[data-group-role="id"]');
				const groupNameElement = card.querySelector<HTMLElement>('[data-group-role="name"]');
				const groupMemoElement = card.querySelector<HTMLElement>('[data-group-role="memo"]');
				const groupIdText = groupIdElement?.textContent?.trim() ?? '';
				const groupNameText = groupNameElement?.textContent?.trim() ?? '';
				const groupMemoText = groupMemoElement?.textContent?.trim() ?? '';

				card.hidden = false;
				card.classList.remove(FILTER_OUT_CLASS);

				return {
					card,
					groupIdElement,
					groupNameElement,
					groupMemoElement,
					sectionId: card.closest('section')?.id,
					labels: labelElements
						.map((element) => element.textContent?.trim().toLowerCase() ?? '')
						.filter(Boolean),
					groupIdLower: groupIdText.toLowerCase(),
					groupNameLower: groupNameText.toLowerCase(),
					groupMemoLower: groupMemoText.toLowerCase(),
					groupIdText,
					groupNameText,
					groupMemoText
				};
			}
		);

		for (const section of sections) {
			section.hidden = false;
			section.classList.remove(FILTER_OUT_CLASS);
		}

		function toggleNoResults(visible: boolean) {
			if (visible) {
				noResultsElement.hidden = false;
				requestAnimationFrame(() => {
					noResultsElement.classList.add(FILTER_VISIBLE_CLASS);
				});
				return;
			}

			noResultsElement.classList.remove(FILTER_VISIBLE_CLASS);
			window.setTimeout(() => {
				if (!noResultsElement.classList.contains(FILTER_VISIBLE_CLASS)) {
					noResultsElement.hidden = true;
				}
			}, FILTER_DELAY);
		}

		function performSearch(searchText: string) {
			const url = new URL(window.location.href);
			if (searchText) {
				url.searchParams.set('q', searchText);
			} else {
				url.searchParams.delete('q');
			}
			window.history.replaceState({}, '', url.toString());

			sectionVisibility.clear();
			let hasVisibleCards = false;

			for (const {
				card,
				groupIdElement,
				groupNameElement,
				groupMemoElement,
				sectionId,
				labels,
				groupIdLower,
				groupNameLower,
				groupMemoLower,
				groupIdText,
				groupNameText,
				groupMemoText
			} of cardCache) {
				if (searchText === '') {
					if (groupIdElement) {
						groupIdElement.textContent = groupIdText;
					}
					if (groupNameElement) {
						groupNameElement.textContent = groupNameText;
					}
					if (groupMemoElement) {
						groupMemoElement.textContent = groupMemoText;
					}
					setAnimatedVisibility(card, true, 'hideTimerId');
					hasVisibleCards = true;
					if (sectionId) {
						sectionVisibility.set(sectionId, true);
					}
					continue;
				}

				const shouldShow =
					labels.some((label) => label.includes(searchText)) ||
					groupNameLower.includes(searchText) ||
					groupIdLower.includes(searchText) ||
					groupMemoLower.includes(searchText);

				if (shouldShow) {
					if (groupIdElement) {
						applyHighlight(groupIdElement, groupIdText, searchText);
					}
					if (groupNameElement) {
						applyHighlight(groupNameElement, groupNameText, searchText);
					}
					if (groupMemoElement) {
						applyHighlight(groupMemoElement, groupMemoText, searchText);
					}
					setAnimatedVisibility(card, true, 'hideTimerId');
					hasVisibleCards = true;
				} else {
					setAnimatedVisibility(card, false, 'hideTimerId');
				}

				if (sectionId) {
					sectionVisibility.set(sectionId, sectionVisibility.get(sectionId) || shouldShow);
				}
			}

			for (let index = 0; index < sections.length; index++) {
				const section = sections[index];
				if (section.id === 'title-section') {
					setAnimatedVisibility(section, true, 'sectionHideTimerId');
					continue;
				}

				let isVisible = sectionVisibility.get(section.id) ?? false;
				if (
					!isVisible &&
					section.firstElementChild?.tagName === 'H2' &&
					index < sections.length - 1
				) {
					const nextSection = sections[index + 1];
					if (
						nextSection.firstElementChild?.tagName === 'H3' &&
						(sectionVisibility.get(nextSection.id) ?? false)
					) {
						isVisible = true;
					}
				}

				setAnimatedVisibility(section, isVisible, 'sectionHideTimerId');
			}

			toggleNoResults(searchText !== '' && !hasVisibleCards);
		}

		function getSearchParam() {
			return new URLSearchParams(window.location.search).get('q') ?? '';
		}

		function clearSearch() {
			searchField.value = '';
			performSearch('');
		}

		let debounceTimer = 0;
		searchField.addEventListener('input', () => {
			window.clearTimeout(debounceTimer);
			debounceTimer = window.setTimeout(() => {
				performSearch(searchField.value.trim().toLowerCase());
			}, 150);
		});

		document.querySelectorAll('#sidebar a').forEach((link) => {
			link.addEventListener('click', (event) => {
				const href = (event.currentTarget as HTMLAnchorElement).getAttribute('href');
				if (href && !href.startsWith('#')) {
					clearSearch();
				}
			});
		});

		document.querySelectorAll('svg a').forEach((link) => {
			link.addEventListener('click', () => {
				clearSearch();
			});
		});

		const searchParam = getSearchParam();
		if (searchParam) {
			searchField.value = searchParam;
			performSearch(searchParam);
			return;
		}

		performSearch('');
	}

	if (!globalScope.__touhouSearchListenersBound) {
		document.addEventListener('astro:page-load', initSearch);
		window.addEventListener('load', initSearch, { once: true });
		globalScope.__touhouSearchListenersBound = true;
	}

	initSearch();
</script>
